<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.agentlego.backend.kb.infrastructure.persistence.KbCollectionMapper">

    <sql id="KbCollection_ColumnList">
        id
        ,
        name,
        description,
        embedding_model_id,
        embedding_dims,
        vector_store_kind,
        vector_store_config::text as vector_store_config_json,
        vector_store_profile_id,
        chunk_strategy,
        chunk_params::text as chunk_params_json,
        created_at,
        updated_at
    </sql>

    <resultMap id="KbCollectionDOMap" type="com.agentlego.backend.kb.infrastructure.persistence.KbCollectionDO">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="embeddingModelId" column="embedding_model_id"/>
        <result property="embeddingDims" column="embedding_dims"/>
        <result property="vectorStoreKind" column="vector_store_kind"/>
        <result property="vectorStoreConfigJson" column="vector_store_config_json"/>
        <result property="vectorStoreProfileId" column="vector_store_profile_id"/>
        <result property="chunkStrategy" column="chunk_strategy"/>
        <result property="chunkParamsJson" column="chunk_params_json"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.agentlego.backend.kb.infrastructure.persistence.KbCollectionDO">
        insert into lego_kb_collections (id, name, description, embedding_model_id, embedding_dims,
                                         vector_store_kind, vector_store_config, vector_store_profile_id,
                                         chunk_strategy, chunk_params, created_at, updated_at)
        values (#{id}, #{name}, #{description}, #{embeddingModelId}, #{embeddingDims},
                #{vectorStoreKind}, CAST(#{vectorStoreConfigJson} AS jsonb), #{vectorStoreProfileId},
                #{chunkStrategy}, CAST(#{chunkParamsJson} AS jsonb),
                #{createdAt}, #{updatedAt})
    </insert>

    <select id="findById" resultMap="KbCollectionDOMap">
        select
        <include refid="KbCollection_ColumnList"/>
        from lego_kb_collections
        where id = #{id}
    </select>

    <select id="listAll" resultMap="KbCollectionDOMap">
        select
        <include refid="KbCollection_ColumnList"/>
        from lego_kb_collections
        order by created_at desc
    </select>

    <select id="findByIds" resultMap="KbCollectionDOMap">
        select
        <include refid="KbCollection_ColumnList"/>
        from lego_kb_collections
        where id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">#{id}</foreach>
    </select>

    <delete id="deleteById">
        delete
        from lego_kb_collections
        where id = #{id}
    </delete>

    <select id="countByVectorStoreProfileId" resultType="int">
        select count(*)
        from lego_kb_collections
        where vector_store_profile_id = #{profileId}
    </select>

    <select id="findByVectorStoreProfileId" resultMap="KbCollectionDOMap">
        select
        <include refid="KbCollection_ColumnList"/>
        from lego_kb_collections
        where vector_store_profile_id = #{profileId}
        order by created_at desc
    </select>
</mapper>
