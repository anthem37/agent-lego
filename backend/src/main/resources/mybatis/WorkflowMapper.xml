<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.agentlego.backend.workflow.infrastructure.persistence.WorkflowMapper">

    <resultMap id="WorkflowDOMap" type="com.agentlego.backend.workflow.infrastructure.persistence.WorkflowDO">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="definitionJson" column="definition_json"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.agentlego.backend.workflow.infrastructure.persistence.WorkflowDO">
        insert into platform_workflows (id, name, definition)
        values (#{id}, #{name}, cast(#{definitionJson} as jsonb))
    </insert>

    <select id="findById" parameterType="java.lang.String" resultMap="WorkflowDOMap">
        select id,
               name,
               cast(definition as text) as definition_json,
               created_at
        from platform_workflows
        where id = #{id}
    </select>
</mapper>

